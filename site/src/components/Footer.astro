---
import { SITE } from "../lib/site";
---

<footer class="mt-24 border-t border-rule/70">
  <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-3 px-5 py-8 text-sm text-ink-dim sm:flex-row">
    <p class="mono text-[0.8rem]">© 2026 {SITE.name} · MIT · runs on your machine</p>
    <div class="mono flex items-center gap-5 text-[0.8rem]">
      <a class="hover:text-ink" href={SITE.releasesLatest} target="_blank" rel="noopener">download</a>
      <a class="hover:text-ink" href={SITE.blog} target="_blank" rel="noopener">blog</a>
      <a class="hover:text-ink" href={SITE.repo} target="_blank" rel="noopener">github</a>
    </div>
  </div>
</footer>
