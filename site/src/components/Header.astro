---
import { SITE, href } from "../lib/site";
---

<header class="sticky top-0 z-30 border-b border-line/70 backdrop-blur supports-[backdrop-filter]:bg-ink/60">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-5 py-3.5">
    <a href={href("/")} class="flex items-center gap-2 font-semibold tracking-tight">
      <span class="grid size-6 place-items-center rounded-md bg-accent/20 text-accent">◆</span>
      {SITE.name}
    </a>
    <nav class="flex items-center gap-1 text-sm text-white/70">
      <a
        class="flex items-center gap-1.5 rounded-lg px-2.5 py-1.5 transition-colors hover:bg-ink-2 hover:text-white"
        href={href("/#features")}
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class="size-4 text-white/45">
          <path d="M3 11l16-6-2.5 16-5-4.5L9 19l-.5-4.8L3 11z" />
        </svg>
        Features
      </a>
      <a
        class="flex items-center gap-1.5 rounded-lg px-2.5 py-1.5 transition-colors hover:bg-ink-2 hover:text-white"
        href={SITE.blog}
        target="_blank"
        rel="noopener"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" class="size-4 text-white/45">
          <rect x="4" y="4" width="16" height="16" rx="2" /><path d="M8 9h8M8 13h8M8 17h5" />
        </svg>
        Blog
      </a>
      <a
        class="flex items-center gap-1.5 rounded-lg px-2.5 py-1.5 transition-colors hover:bg-ink-2 hover:text-white"
        href={SITE.repo}
        target="_blank"
        rel="noopener"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" class="size-4 text-white/45">
          <path d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49 0-.24-.01-.88-.01-1.73-2.78.62-3.37-1.37-3.37-1.37-.45-1.18-1.11-1.49-1.11-1.49-.91-.64.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.36-2.22-.26-4.56-1.14-4.56-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.27 2.75 1.05A9.34 9.34 0 0 1 12 6.84c.85 0 1.71.12 2.51.34 1.91-1.32 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.81-4.57 5.06.36.32.68.94.68 1.9 0 1.37-.01 2.48-.01 2.82 0 .27.18.6.69.49A10.02 10.02 0 0 0 22 12.25C22 6.58 17.52 2 12 2z" />
        </svg>
        GitHub
      </a>
      <a
        class="ml-2 rounded-lg bg-accent px-3 py-1.5 font-medium text-white shadow-sm transition-colors hover:bg-accent/90"
        href={SITE.releasesLatest}
        target="_blank"
        rel="noopener"
      >
        Download
      </a>
    </nav>
  </div>
</header>
