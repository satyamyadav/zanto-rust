---
import Base from "../layouts/Base.astro";
import { SITE, href } from "../lib/site";

const providers = [
  "Anthropic", "OpenAI", "Gemini", "Groq", "xAI",
  "DeepSeek", "Together", "Fireworks", "Cohere", "Ollama",
];
---

<Base>
  <!-- ══ 1 · The complete app, on your desk ══════════════════════════════ -->
  <section class="mx-auto max-w-6xl px-5 pt-14 pb-8 sm:pt-20">
    <div class="mx-auto max-w-3xl text-center">
      <p class="eyebrow">local-first · yours · offline-capable</p>
      <h1 class="mx-auto mt-4 max-w-2xl text-balance text-4xl font-semibold leading-[1.05] tracking-tight sm:text-5xl">
        The AI workspace that lives on your machine.
      </h1>
      <p class="mx-auto mt-4 max-w-xl text-pretty text-ink-dim">
        Your key, your files, your models. zanto talks straight to the provider you pick — or to Ollama, fully offline. Nothing routes through us.
      </p>
      <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
        <a
          href={SITE.releasesLatest}
          target="_blank"
          rel="noopener"
          class="rounded-lg bg-signal px-5 py-2.5 font-medium text-desk transition-transform hover:-translate-y-0.5"
        >
          Download for your OS
        </a>
        <a
          href="#tour"
          class="mono rounded-lg border border-rule bg-panel px-5 py-2.5 text-[0.85rem] text-ink-dim hover:text-ink"
        >
          take the tour ↓
        </a>
      </div>
      <p class="mono mt-3 text-[0.72rem] text-ink-faint">macOS · Windows · Linux — install in seconds</p>
    </div>

    <!-- The whole window, rendered in HTML, set on the desk. -->
    <div class="appframe appframe-tilt reveal mx-auto mt-12 max-w-5xl overflow-hidden" data-panel>
      <!-- title bar -->
      <div class="flex items-center gap-2 border-b border-rule px-4 py-2.5">
        <span class="dot"></span><span class="dot"></span><span class="dot"></span>
        <span class="mono ml-2 text-[0.72rem] text-ink-faint">zanto — local session</span>
        <span class="mono ml-auto flex items-center gap-1.5 text-[0.72rem] text-signal">
          <span class="size-1.5 rounded-full bg-signal"></span> on this device
        </span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-[196px_1fr_248px]">
        <!-- sidebar -->
        <aside class="hidden flex-col border-r border-rule bg-panel/60 p-3 md:flex">
          <div class="flex items-center gap-2 rounded-md bg-panel-2 px-2.5 py-1.5 text-sm">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="size-4 text-ink-dim"><rect x="4" y="5" width="16" height="14" rx="2"/><path d="M8 10h8M8 14h5"/></svg>
            Chat
          </div>
          <p class="eyebrow mt-4 px-1">apps</p>
          <div class="mt-1.5 rounded-md px-2.5 py-1.5 text-sm text-ink-dim">Personal Finance</div>
          <p class="eyebrow mt-4 px-1">chats</p>
          <div class="mt-1.5 rounded-md border border-wire/25 bg-wire/5 px-2.5 py-2">
            <div class="text-sm text-ink">Summarize my spending</div>
            <div class="mono mt-0.5 text-[0.68rem] text-ink-faint">just now · 8 msgs</div>
          </div>
          <div class="mt-auto flex items-center justify-between border-t border-rule pt-3">
            <span class="mono text-[0.7rem] text-ink-faint">gemini-3.5-flash</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="size-4 text-ink-faint"><circle cx="12" cy="12" r="3"/><path d="M12 3v2M12 19v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M3 12h2M19 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4"/></svg>
          </div>
        </aside>

        <!-- chat column -->
        <div class="flex min-w-0 flex-col bg-desk/40">
          <div class="flex-1 space-y-2.5 p-4">
            <!-- tool call, resolved -->
            <div class="stream flex items-center gap-2 rounded-md border border-rule bg-panel px-3 py-1.5 text-sm" style="animation-delay:.15s">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" class="size-3.5 text-ink-faint"><path d="M9 6l6 6-6 6"/></svg>
              <span class="mono text-ink-dim">read_document</span>
              <span class="mono ml-auto flex items-center gap-1 rounded bg-signal/12 px-1.5 py-0.5 text-[0.68rem] text-signal">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-3"><path d="M20 6L9 17l-5-5"/></svg> done
              </span>
            </div>
            <!-- thinking, collapsed -->
            <div class="stream flex items-center gap-2 rounded-md border border-rule/60 px-3 py-1.5 text-sm text-ink-faint" style="animation-delay:.3s">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" class="size-3.5"><path d="M6 9l6 6 6-6"/></svg>
              <span class="mono truncate">focusing on a clear summary of transactions.csv…</span>
            </div>
            <!-- assistant line -->
            <p class="stream max-w-md text-sm text-ink/90" style="animation-delay:.45s">
              Here's where your money went last month — rent dominates at 83.6%.
            </p>

            <!-- artifact: donut -->
            <div class="stream rounded-lg border border-rule bg-panel p-3" style="animation-delay:.8s">
              <div class="mb-2 flex items-center justify-between">
                <span class="mono text-[0.72rem] text-ink-dim">Expenses by category · 4,187.70 AED</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="size-3.5 text-ink-faint"><path d="M12 3v18M6 9l6-6 6 6"/></svg>
              </div>
              <div class="flex items-center gap-4">
                <div class="donut size-24 shrink-0 rounded-full"></div>
                <ul class="mono space-y-1 text-[0.72rem] text-ink-dim">
                  <li><span class="mr-1.5 inline-block size-2 rounded-full align-middle" style="background:var(--color-wire)"></span>Rent · 83.6%</li>
                  <li><span class="mr-1.5 inline-block size-2 rounded-full align-middle" style="background:var(--color-signal)"></span>Utilities · 6.0%</li>
                  <li><span class="mr-1.5 inline-block size-2 rounded-full align-middle bg-[#f4b740]"></span>Groceries · 4.4%</li>
                  <li><span class="mr-1.5 inline-block size-2 rounded-full align-middle bg-[#e2705f]"></span>Dining · 2.6%</li>
                </ul>
              </div>
            </div>

            <!-- artifact: table -->
            <div class="stream overflow-hidden rounded-lg border border-rule bg-panel" style="animation-delay:1.05s">
              <div class="border-b border-rule px-3 py-1.5">
                <span class="mono text-[0.72rem] text-ink-dim">Summary of transactions.csv</span>
              </div>
              <table class="w-full text-sm">
                <tbody class="mono text-[0.78rem]">
                  {[["Rent (ADIB)", "3,500.00", "83.6%"], ["Utilities", "250.00", "6.0%"], ["Groceries", "185.50", "4.4%"]].map((r) => (
                    <tr class="border-b border-rule/60 last:border-0">
                      <td class="px-3 py-1.5 text-ink/85">{r[0]}</td>
                      <td class="px-3 py-1.5 text-right text-ink-dim tabular">{r[1]}</td>
                      <td class="px-3 py-1.5 text-right text-ink-faint tabular">{r[2]}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>

          <!-- composer -->
          <div class="border-t border-rule p-3">
            <div class="flex items-center gap-2 rounded-lg border border-wire/40 bg-panel px-3 py-2.5">
              <span class="mono text-sm text-ink-dim caret">Ask about last month</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" class="ml-auto size-4 text-ink-faint"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </div>
          </div>
        </div>

        <!-- canvas -->
        <aside class="hidden flex-col items-center justify-center border-l border-rule bg-panel/40 p-5 text-center lg:flex">
          <div class="grid size-10 place-items-center rounded-lg border border-rule text-ink-faint">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="size-5"><rect x="4" y="4" width="16" height="16" rx="2"/><path d="M4 9h16M9 9v11"/></svg>
          </div>
          <p class="mt-3 text-sm text-ink-dim">Canvas</p>
          <p class="mono mt-1 text-[0.7rem] leading-relaxed text-ink-faint">pinned charts &amp;<br />tables open here</p>
        </aside>
      </div>
    </div>
  </section>

  <!-- ══ 2 · The tour — one feature at a time ════════════════════════════ -->
  <section id="tour" class="mx-auto max-w-6xl px-5 py-8">
    <div class="border-t border-rule pt-10">
      <p class="eyebrow">the tour</p>
      <h2 class="mt-2 max-w-xl text-2xl font-semibold tracking-tight sm:text-3xl">What it does, panel by panel.</h2>
    </div>

    <div class="mt-16 space-y-24">
      <!-- providers -->
      <article data-panel class="grid items-center gap-10 lg:grid-cols-[1fr_1.05fr]">
        <div class="reveal">
          <p class="eyebrow">providers</p>
          <h3 class="mt-2 text-2xl font-semibold tracking-tight">Any model, no lock-in.</h3>
          <p class="mt-3 max-w-md text-ink-dim">
            Ten providers behind one window — Anthropic, OpenAI, Gemini, Groq, xAI, DeepSeek and more, or Ollama offline. Keys sit in your OS keychain. Switch mid-conversation; nothing restarts.
          </p>
        </div>
        <div class="reveal">
          <div class="appframe overflow-hidden p-5">
            <div class="flex items-center justify-between">
              <span class="mono text-[0.72rem] text-ink-faint">active model</span>
              <span class="mono rounded-md border border-rule bg-panel-2 px-2 py-1 text-[0.78rem] text-ink" data-model>claude-opus-4-8</span>
            </div>
            <div class="mono mt-4 flex flex-wrap gap-2 text-[0.82rem]" data-chips>
              {providers.slice(0, 7).map((p, i) => (
                <button type="button" data-provider={p} data-on={i === 0 ? "true" : "false"} class="chip rounded-md px-3 py-1.5">{p}</button>
              ))}
            </div>
            <p class="mono mt-4 flex items-center gap-1.5 text-[0.72rem] text-signal">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="size-3.5"><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z"/></svg>
              keys stay in the OS keychain
            </p>
          </div>
        </div>
      </article>

      <!-- consent -->
      <article data-panel class="grid items-center gap-10 lg:grid-cols-[1.05fr_1fr]">
        <div class="reveal order-2 lg:order-1">
          <div class="appframe overflow-hidden p-4">
            <div class="mono flex items-center gap-2 text-sm text-ink-dim">
              <span class="rounded bg-panel-2 px-1.5 py-0.5 text-[0.68rem]">tool</span>
              write_file → <span class="text-ink">report.md</span>
            </div>
            <div class="mt-3 rounded-lg border border-wire/30 bg-wire/5 p-3">
              <div class="flex items-center gap-2 text-sm text-ink/90">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" class="size-4 text-wire"><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z"/></svg>
                Write to <span class="mono">~/notes/report.md</span>?
              </div>
              <div class="mono mt-3 flex gap-2 text-[0.78rem]">
                <span class="rounded-md bg-signal px-3 py-1.5 font-medium text-desk">Allow</span>
                <span class="rounded-md border border-rule px-3 py-1.5 text-ink-dim">Deny</span>
                <span class="rounded-md border border-rule px-3 py-1.5 text-ink-dim">Always</span>
              </div>
            </div>
            <div class="mono mt-2 flex flex-wrap gap-1.5 text-[0.68rem] text-ink-faint">
              {["read", "write", "edit", "shell", "web fetch", "docs"].map((t) => (
                <span class="rounded bg-panel-2 px-1.5 py-0.5">{t}</span>
              ))}
            </div>
          </div>
        </div>
        <div class="reveal order-1 lg:order-2">
          <p class="eyebrow">consent</p>
          <h3 class="mt-2 text-2xl font-semibold tracking-tight">It acts only when you say so.</h3>
          <p class="mt-3 max-w-md text-ink-dim">
            Read, write and edit files, run shell commands, fetch the web, parse PDFs and Office docs. Every file or shell action asks first — per path — and you can grant it once or for good.
          </p>
        </div>
      </article>

      <!-- artifacts -->
      <article data-panel class="grid items-center gap-10 lg:grid-cols-[1fr_1.05fr]">
        <div class="reveal">
          <p class="eyebrow">artifacts</p>
          <h3 class="mt-2 text-2xl font-semibold tracking-tight">Answers you can keep.</h3>
          <p class="mt-3 max-w-md text-ink-dim">
            Structured replies render as real charts, tables and metrics — inline, or pinned to a side canvas you can come back to. Sandboxed HTML pages, too.
          </p>
        </div>
        <div class="reveal">
          <div class="grid grid-cols-2 gap-3">
            <div class="appframe p-4">
              <div class="mono text-[0.72rem] text-ink-faint">net worth</div>
              <div class="tabular mt-1 text-2xl font-semibold text-signal" data-countup data-to="48210" data-prefix="$">$0</div>
              <div class="mono mt-1 text-[0.68rem] text-signal">▲ 6.2% this month</div>
            </div>
            <div class="appframe grid place-items-center p-4">
              <div class="donut size-16 rounded-full"></div>
            </div>
            <div class="appframe col-span-2 overflow-hidden p-4">
              <div class="mono text-[0.72rem] text-ink-faint">recent</div>
              <div class="mono mt-2 space-y-1.5 text-[0.8rem]">
                {[["Whole Foods", "−$77.80", "dim"], ["Salary", "+$3,200", "signal"], ["Uber", "−$22.10", "dim"]].map((r, i) => (
                  <div class="stream flex items-center justify-between border-b border-rule/60 pb-1.5 last:border-0" style={`animation-delay:${0.4 + i * 0.2}s`}>
                    <span class="text-ink-dim">{r[0]}</span>
                    <span class:list={["tabular", r[2] === "signal" ? "text-signal" : "text-ink-dim"]}>{r[1]}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </article>

      <!-- sessions -->
      <article data-panel class="grid items-center gap-10 lg:grid-cols-[1.05fr_1fr]">
        <div class="reveal order-2 lg:order-1">
          <div class="appframe overflow-hidden p-4">
            <div class="mono mb-2 flex items-center justify-between text-[0.72rem] text-ink-faint">
              <span>chats</span><span>SQLite · crash-safe</span>
            </div>
            <div class="space-y-1.5">
              <div class="stream flex items-center justify-between rounded-md border border-wire/25 bg-wire/5 px-3 py-2" style="animation-delay:.15s">
                <div>
                  <div class="text-sm text-ink">Q2 revenue analysis</div>
                  <div class="mono text-[0.68rem] text-ink-faint">resumed · 42 msgs</div>
                </div>
                <span class="mono rounded-full bg-signal/12 px-2 py-0.5 text-[0.66rem] text-signal">live</span>
              </div>
              <div class="stream flex items-center justify-between rounded-md px-3 py-2" style="animation-delay:.4s">
                <div>
                  <div class="text-sm text-ink-dim">Finance import</div>
                  <div class="mono text-[0.68rem] text-ink-faint">yesterday · 18 msgs</div>
                </div>
                <span class="mono rounded-full bg-panel-2 px-2 py-0.5 text-[0.66rem] text-ink-faint">summarized</span>
              </div>
              <div class="stream flex items-center justify-between rounded-md px-3 py-2" style="animation-delay:.6s">
                <div class="text-sm text-ink-dim">Refactor plan</div>
                <span class="mono text-[0.68rem] text-ink-faint">2d ago</span>
              </div>
            </div>
          </div>
        </div>
        <div class="reveal order-1 lg:order-2">
          <p class="eyebrow">sessions</p>
          <h3 class="mt-2 text-2xl font-semibold tracking-tight">Close it. Reopen it. Keep going.</h3>
          <p class="mt-3 max-w-md text-ink-dim">
            Every message lands in a local SQLite store the moment it happens, so a crash costs nothing. Long threads summarize themselves to stay fast — and stay yours.
          </p>
        </div>
      </article>

      <!-- finance app -->
      <article data-panel class="grid items-center gap-10 lg:grid-cols-[1fr_1.05fr]">
        <div class="reveal">
          <p class="eyebrow">apps</p>
          <h3 class="mt-2 text-2xl font-semibold tracking-tight">Focused apps on the same engine.</h3>
          <p class="mt-3 max-w-md text-ink-dim">
            Personal Finance is the first: import a bank statement and zanto categorizes it, tracks budgets, accounts and net worth — and answers questions about your money. All local.
          </p>
          <a href={SITE.releasesLatest} target="_blank" rel="noopener" class="mono mt-5 inline-block rounded-md border border-rule bg-panel px-4 py-2 text-[0.82rem] text-ink-dim hover:text-ink">
            try it free →
          </a>
        </div>
        <div class="reveal">
          <div class="appframe overflow-hidden">
            <div class="mono flex items-center gap-3 border-b border-rule px-4 py-2.5 text-[0.72rem] text-ink-faint">
              <span class="rounded bg-signal/12 px-2 py-0.5 text-signal">Dashboard</span>
              <span>Transactions</span><span>Accounts</span><span>Import</span>
            </div>
            <div class="space-y-3 p-4">
              <div class="rounded-lg border border-rule bg-panel-2 p-3">
                <div class="mono text-[0.7rem] text-ink-faint">safe to spend</div>
                <div class="tabular mt-0.5 text-2xl font-semibold" data-countup data-to="2336.93" data-prefix="AED " data-decimals="2">AED 0.00</div>
              </div>
              <div class="rounded-lg border border-rule bg-panel-2 p-3">
                <div class="mono mb-2 text-[0.7rem] text-ink-faint">cashflow · 6 months</div>
                <div class="flex h-16 items-end gap-1.5">
                  {[40, 55, 48, 62, 58, 72].map((h, i) => (
                    <div class="flex w-full flex-col justify-end gap-0.5" style="height:100%">
                      <div class="bar rounded-t bg-signal/70" style={`height:${h * 0.42}%;animation-delay:${0.25 + i * 0.07}s`}></div>
                      <div class="bar rounded-t bg-wire/60" style={`height:${h * 0.32}%;animation-delay:${0.3 + i * 0.07}s`}></div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      </article>
    </div>
  </section>

  <!-- ══ 3 · Provider strip ══════════════════════════════════════════════ -->
  <section class="mx-auto max-w-6xl px-5 py-8">
    <div class="border-t border-rule pt-10 text-center">
      <p class="eyebrow">works with</p>
      <div class="mono mx-auto mt-4 flex max-w-3xl flex-wrap items-center justify-center gap-2 text-[0.82rem]">
        {providers.map((p) => (
          <span class="rounded-md border border-rule bg-panel/60 px-3 py-1 text-ink-dim transition-colors hover:border-wire/40 hover:text-ink">{p}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ 4 · See it in motion (video last) ═══════════════════════════════ -->
  <section class="mx-auto max-w-6xl px-5 py-8">
    <div class="reveal border-t border-rule pt-10" data-panel>
      <p class="eyebrow">in motion</p>
      <h2 class="mt-2 max-w-xl text-2xl font-semibold tracking-tight sm:text-3xl">A minute of the real thing.</h2>
      <div class="appframe mx-auto mt-8 max-w-4xl overflow-hidden">
        <div class="flex items-center gap-2 border-b border-rule px-4 py-2.5">
          <span class="dot"></span><span class="dot"></span><span class="dot"></span>
          <span class="mono ml-2 text-[0.72rem] text-ink-faint">zanto — screen recording</span>
        </div>
        <video
          class="block w-full"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          poster={href("/og.png")}
        >
          <source src={href("/hero.webm")} type="video/webm" />
          <source src={href("/hero.mp4")} type="video/mp4" />
        </video>
      </div>
    </div>
  </section>

  <!-- ══ 5 · Close ═══════════════════════════════════════════════════════ -->
  <section class="mx-auto max-w-6xl px-5 py-16">
    <div class="appframe overflow-hidden p-8 text-center sm:p-12">
      <h2 class="mx-auto max-w-lg text-balance text-2xl font-semibold tracking-tight sm:text-3xl">
        Keep your work on your machine.
      </h2>
      <p class="mx-auto mt-3 max-w-md text-ink-dim">
        Free, open-source, and private by construction. Your files, keys and conversations never leave the device.
      </p>
      <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
        <a href={SITE.releasesLatest} target="_blank" rel="noopener" class="rounded-lg bg-signal px-5 py-2.5 font-medium text-desk transition-transform hover:-translate-y-0.5">
          Download for your OS
        </a>
        <a href={SITE.repo} target="_blank" rel="noopener" class="mono rounded-lg border border-rule bg-panel px-5 py-2.5 text-[0.85rem] text-ink-dim hover:text-ink">
          view source
        </a>
      </div>
    </div>
  </section>

  <!-- Reveal on scroll, count-ups, and the one interactive bit (provider switch). -->
  <script is:inline>
    (() => {
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      function countUp(el) {
        const to = parseFloat(el.dataset.to || "0");
        const dp = parseInt(el.dataset.decimals || "0", 10);
        const prefix = el.dataset.prefix || "";
        const fmt = (n) => prefix + n.toLocaleString(undefined, { minimumFractionDigits: dp, maximumFractionDigits: dp });
        if (reduce) { el.textContent = fmt(to); return; }
        const dur = 1100, t0 = performance.now();
        const step = (t) => {
          const p = Math.min(1, (t - t0) / dur);
          el.textContent = fmt(to * (1 - Math.pow(1 - p, 3)));
          if (p < 1) requestAnimationFrame(step);
        };
        requestAnimationFrame(step);
      }

      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (!e.isIntersecting) continue;
          e.target.classList.add("in-view");
          e.target.querySelectorAll("[data-countup]").forEach(countUp);
          io.unobserve(e.target);
        }
      }, { threshold: 0.25 });
      document.querySelectorAll(".reveal, [data-panel]").forEach((n) => io.observe(n));

      // Provider switcher: click to select; gently auto-cycles until touched.
      const MODEL = {
        Anthropic: "claude-opus-4-8", OpenAI: "gpt-5", Gemini: "gemini-2.5-pro",
        Groq: "llama-4-70b", xAI: "grok-4", DeepSeek: "deepseek-v3", Together: "qwen-2.5-72b",
      };
      const chips = document.querySelector("[data-chips]");
      const modelEl = document.querySelector("[data-model]");
      function select(name) {
        chips?.querySelectorAll("[data-provider]").forEach((c) => c.dataset.on = String(c.dataset.provider === name));
        if (modelEl) modelEl.textContent = MODEL[name] || name;
      }
      chips?.querySelectorAll("[data-provider]").forEach((c) => c.addEventListener("click", () => select(c.dataset.provider)));
      if (!reduce && chips) {
        const names = Object.keys(MODEL);
        let i = 0, touched = false;
        chips.addEventListener("click", () => { touched = true; }, { once: true });
        setInterval(() => { if (!touched) select(names[++i % names.length]); }, 2000);
      }
    })();
  </script>
</Base>
