---
import Base from "../layouts/Base.astro";
import { SITE, href } from "../lib/site";

const providers = [
  "Anthropic", "OpenAI", "Gemini", "Groq", "xAI",
  "DeepSeek", "Together", "Fireworks", "Cohere", "Ollama",
];

// Inline line icons (24×24, stroke=currentColor) — themed per feature, no icon lib.
const ICON = {
  key: '<path d="M15 7a4 4 0 1 0-3.9 5h.9l2 2 1.5-1.5L17 14l1.5-1.5L20 14l1.5-1.5L15 6"/><circle cx="15" cy="7" r="0"/><path d="M12.5 11.5 3 21v0h3v-2h2v-2h2l1.5-1.5"/>',
  swap: '<path d="M4 7h11l-2.5-2.5M20 17H9l2.5 2.5"/><path d="M16 4.5 20 7l-4 2.5M8 14.5 4 17l4 2.5"/>',
  shield: '<path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z"/><path d="M9 12l2 2 4-4"/>',
  chart: '<path d="M4 20V4M4 20h16"/><rect x="7" y="12" width="3" height="5"/><rect x="12" y="8" width="3" height="9"/><rect x="17" y="5" width="3" height="12"/>',
  database: '<ellipse cx="12" cy="5" rx="7" ry="3"/><path d="M5 5v6c0 1.7 3.1 3 7 3s7-1.3 7-3V5"/><path d="M5 11v6c0 1.7 3.1 3 7 3s7-1.3 7-3v-6"/>',
  grid: '<rect x="4" y="4" width="7" height="7" rx="1.5"/><rect x="13" y="4" width="7" height="7" rx="1.5"/><rect x="4" y="13" width="7" height="7" rx="1.5"/><rect x="13" y="13" width="7" height="7" rx="1.5"/>',
};

const features = [
  {
    icon: ICON.key,
    title: "You own the stack",
    body: "Bring your own API key (stored in the OS keychain), or run fully offline against local Ollama. No middleman server, ever.",
  },
  {
    icon: ICON.swap,
    title: "10+ providers, one app",
    body: "Switch models live across Anthropic, OpenAI, Gemini, Groq, xAI, DeepSeek and more. Tune generation params globally or per provider.",
  },
  {
    icon: ICON.shield,
    title: "Real tools, with consent",
    body: "Read, write, search and edit files; run shell commands; fetch the web; parse PDFs and Office docs — every file action is permission-gated.",
  },
  {
    icon: ICON.chart,
    title: "Artifacts, not just chat",
    body: "Answers render as charts, tables, metrics and documents — inline or on a side canvas. Pin the ones worth keeping.",
  },
  {
    icon: ICON.database,
    title: "Sessions that survive",
    body: "SQLite-backed, crash-safe and resumable, with automatic context summarization for long conversations.",
  },
  {
    icon: ICON.grid,
    title: "Apps on the same engine",
    body: "Focused micro-apps on top of the same private engine — starting with Personal Finance: transactions, budgets, accounts and net worth, all local.",
  },
];
---

<Base>
  <!-- Hero -->
  <section class="mx-auto max-w-5xl px-5 pt-20 pb-16 text-center">
    <h1 class="mx-auto max-w-3xl text-balance text-5xl font-semibold leading-[1.05] tracking-tight sm:text-6xl">
A private, local-first AI workspace<br />for your desktop.
    </h1>
    <p class="mx-auto mt-5 max-w-2xl text-pretty text-lg text-white/60">
      {SITE.description}
    </p>
    <div class="mt-8 flex items-center justify-center gap-3">
      <a
        href={SITE.releasesLatest}
        target="_blank"
        rel="noopener"
        class="rounded-xl bg-accent px-5 py-3 font-medium text-white shadow-lg shadow-accent/20 transition-transform hover:-translate-y-0.5"
      >
        Download for your OS
      </a>
      <a
        href={SITE.repo}
        target="_blank"
        rel="noopener"
        class="rounded-xl border border-line bg-ink-2 px-5 py-3 font-medium text-white/80 hover:text-white"
      >
        View on GitHub
      </a>
    </div>
    <p class="mt-4 text-xs text-white/40">macOS · Windows · Linux — unsigned builds, install in seconds.</p>

    <!-- Demo loop -->
    <div class="mx-auto mt-12 max-w-4xl overflow-hidden rounded-2xl border border-line bg-ink-2 shadow-2xl shadow-black/40">
      <video
        class="block w-full"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster={href("/og.png")}
      >
        <source src={href("/hero.webm")} type="video/webm" />
        <source src={href("/hero.mp4")} type="video/mp4" />
      </video>
    </div>

    <!-- Provider strip -->
    <p class="mt-14 text-xs font-medium uppercase tracking-wider text-white/35">Works with</p>
    <div class="mx-auto mt-4 flex max-w-3xl flex-wrap items-center justify-center gap-2">
      {providers.map((p) => (
        <span class="rounded-full border border-line bg-ink-2/60 px-3 py-1 text-sm text-white/55 transition-colors hover:border-accent/40 hover:text-white/80">
          {p}
        </span>
      ))}
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="mx-auto max-w-5xl px-5 py-12">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((f) => (
        <div class="rounded-2xl border border-line bg-ink-2/60 p-6 transition-colors hover:border-accent/40">
          <div class="grid size-10 place-items-center rounded-xl border border-accent/20 bg-accent/10 text-accent">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="size-5"
              set:html={f.icon}
            />
          </div>
          <h3 class="mt-4 text-base font-semibold tracking-tight">{f.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-white/55">{f.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Privacy band -->
  <section class="mx-auto max-w-5xl px-5 py-12">
    <div class="rounded-2xl border border-line bg-gradient-to-br from-accent/10 to-transparent p-8 sm:p-10">
      <h2 class="max-w-2xl text-2xl font-semibold tracking-tight">Private by design.</h2>
      <p class="mt-3 max-w-2xl text-white/60">
        zanto runs on your machine and talks directly to the model provider you choose —
        or to a model running locally. Your files, keys and conversations stay with you.
      </p>
      <a href={SITE.releasesLatest} target="_blank" rel="noopener" class="mt-6 inline-block rounded-lg bg-white px-4 py-2 font-medium text-ink hover:bg-white/90">
        Get started →
      </a>
    </div>
  </section>
</Base>
