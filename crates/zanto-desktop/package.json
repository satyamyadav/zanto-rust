    "@tauri-apps/plugin-os": "^2.3.2",
    "ajv": "^8.20.0",
    "apexcharts": "^5.15.0",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.10",
    "marked": "^18.0.5",
    "svelte-textarea-autosize": "^1.0.0",
