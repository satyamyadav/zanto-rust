{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "zanto",
  "version": "1.0.0",
  "identifier": "com.lazy.zanto",
  "build": {
    "beforeDevCommand": "pnpm run dev:web",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build:web",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "zanto",
        "width": 1100,
        "height": 740,
        "minWidth": 900,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "A local-first AI workspace for your desktop.",
    "longDescription": "zanto is a local-first AI assistant: bring your own API key (stored in the OS keychain) or run fully offline against local Ollama. Switch between 10+ model providers, give the assistant consented access to your files, shell, and the web, and render results as charts, tables, and documents.",
    "homepage": "https://github.com/satyamyadav/zanto-rust",
    "publisher": "zanto",
    "copyright": "Copyright © 2026 zanto",
    "licenseFile": "../../../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
