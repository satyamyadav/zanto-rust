[
  {
    "id": "table",
    "description": "A table with named columns and rows.",
    "when_to_use": "Tabular data — lists of records, comparisons.",
    "data_schema": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "columns": { "type": "array", "items": { "type": "string" } },
        "rows": { "type": "array", "items": { "type": "array" } }
      },
      "required": ["columns", "rows"]
    }
  },
  {
    "id": "metric",
    "description": "A single headline value with a label.",
    "when_to_use": "A KPI, total, or one important number.",
    "data_schema": {
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "value": {},
        "unit": { "type": "string" }
      },
      "required": ["label", "value"]
    }
  },
  {
    "id": "chart",
    "description": "A bar, line, pie, or doughnut chart over labelled datasets.",
    "when_to_use": "Visualising trends, comparisons, or distributions across categories.",
    "data_schema": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["bar", "line", "pie", "doughnut"] },
        "title": { "type": "string" },
        "labels": { "type": "array", "items": { "type": "string" } },
        "datasets": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "data": { "type": "array", "items": { "type": "number" } }
            },
            "required": ["data"]
          }
        }
      },
      "required": ["type", "labels", "datasets"]
    }
  },
  {
    "id": "list",
    "description": "A bulleted list of items.",
    "when_to_use": "Simple enumerations.",
    "data_schema": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "items": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["items"]
    }
  },
  {
    "id": "kv",
    "description": "Key/value pairs.",
    "when_to_use": "Attributes or a small record.",
    "data_schema": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "pairs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": { "key": { "type": "string" }, "value": {} },
            "required": ["key", "value"]
          }
        }
      },
      "required": ["pairs"]
    }
  },
  {
    "id": "json",
    "description": "Raw JSON, pretty-printed. Fallback for anything structured.",
    "when_to_use": "When no specific artifact fits the data.",
    "data_schema": { "type": "object" }
  },
  {
    "id": "nba",
    "description": "Next best actions — suggested actions as clickable buttons; each sends its prompt as a new message.",
    "when_to_use": "Offer the user concrete follow-up actions to take next.",
    "data_schema": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "actions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "prompt": { "type": "string" },
              "icon": { "type": "string" }
            },
            "required": ["label", "prompt"]
          }
        }
      },
      "required": ["actions"]
    }
  },
  {
    "id": "transactions_table",
    "description": "Finance transactions table.",
    "when_to_use": "Showing the user's transactions.",
    "data_schema": {
      "type": "object",
      "properties": { "rows": { "type": "array" } },
      "required": ["rows"]
    }
  },
  {
    "id": "monthly_summary",
    "description": "Finance monthly spending summary (total + per-category).",
    "when_to_use": "Monthly spending totals and breakdown.",
    "data_schema": {
      "type": "object",
      "properties": {
        "month": { "type": "string" },
        "total": { "type": "number" },
        "by_category": { "type": "array" }
      },
      "required": ["month", "total", "by_category"]
    }
  }
]
