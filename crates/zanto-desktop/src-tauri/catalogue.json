[
  {
    "id": "table",
    "storage": "view",
    "description": "A table with named columns and rows.",
    "when_to_use": "Tabular data — lists of records, comparisons.",
    "data_schema": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "columns": { "type": "array", "items": { "type": "string" } },
        "rows": { "type": "array", "items": { "type": "array" } }
      },
      "required": ["columns", "rows"]
    }
  },
  {
    "id": "metric",
    "storage": "view",
    "description": "A single headline value with a label.",
    "when_to_use": "A KPI, total, or one important number.",
    "data_schema": {
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "value": {},
        "unit": { "type": "string" }
      },
      "required": ["label", "value"]
    }
  },
  {
    "id": "chart",
    "storage": "view",
    "description": "A bar, line, pie, or doughnut chart over labelled datasets.",
    "when_to_use": "Visualising trends, comparisons, or distributions across categories.",
    "data_schema": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["bar", "line", "pie", "doughnut"] },
        "title": { "type": "string" },
        "labels": { "type": "array", "items": { "type": "string" } },
        "datasets": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "data": { "type": "array", "items": { "type": "number" } }
            },
            "required": ["data"]
          }
        }
      },
      "required": ["type", "labels", "datasets"]
    }
  },
  {
    "id": "markdown",
    "storage": "file",
    "description": "Rendered markdown document — sanitized HTML from a markdown string.",
    "when_to_use": "Agent-produced prose documents, notes, or previewing stored markdown.",
    "data_schema": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" }
      },
      "required": ["content"]
    }
  },
  {
    "id": "html",
    "storage": "file",
    "description": "Render a self-contained HTML page. It runs in a locked-down sandbox: inline <script> executes, but the page has NO network access (fetch/XHR/websockets and all remote/CDN resources are blocked) and NO access to the app, your data, or the host. Emit a full HTML document as `content`.",
    "when_to_use": "When the user wants a custom interactive page or visualisation that the fixed components (chart, table, metric, …) cannot express. Inline everything — <style> and <script> only; external/CDN URLs will not load. Prefer the simpler components when they fit.",
    "data_schema": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" }
      },
      "required": ["content"]
    }
  },
  {
    "id": "page",
    "storage": "file",
    "description": "A complete multi-section document — an ordered list of markdown sections, each with an optional heading, rendered as one composed page.",
    "when_to_use": "Composed reports or documents made of several titled sections; save as a markdown file with store_artifact.",
    "data_schema": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "heading": { "type": "string" },
              "markdown": { "type": "string" }
            },
            "required": ["markdown"]
          }
        }
      },
      "required": ["sections"]
    }
  },
  {
    "id": "list",
    "storage": "view",
    "description": "A bulleted list of items.",
    "when_to_use": "Simple enumerations.",
    "data_schema": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "items": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["items"]
    }
  },
  {
    "id": "kv",
    "storage": "view",
    "description": "Key/value pairs.",
    "when_to_use": "Attributes or a small record.",
    "data_schema": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "pairs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": { "key": { "type": "string" }, "value": {} },
            "required": ["key", "value"]
          }
        }
      },
      "required": ["pairs"]
    }
  },
  {
    "id": "json",
    "storage": "view",
    "description": "Raw JSON, pretty-printed. Fallback for anything structured.",
    "when_to_use": "When no specific artifact fits the data.",
    "data_schema": { "type": "object" }
  },
  {
    "id": "nba",
    "storage": "view",
