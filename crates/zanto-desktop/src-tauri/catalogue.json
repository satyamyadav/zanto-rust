    "data_schema": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "actions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "prompt": { "type": "string" },
              "icon": { "type": "string" }
            },
            "required": ["label", "prompt"]
          }
        }
      },
      "required": ["actions"]
    }
  },
  {
