{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "zanto",
  "version": "0.1.0",
  "identifier": "com.zanto.desktop",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ui",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build --prefix ui",
    "frontendDist": "ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "zanto",
        "width": 1100,
        "height": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
